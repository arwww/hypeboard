# A descriptive User-Agent is required by Wikimedia and is good practice for all providers.
HYPEBOARD_USER_AGENT=Hypeboard/1.0 (contact: your-email@example.com)

# Default market adapter. The provider is isolated behind pipeline/sources/market_data.py.
HYPEBOARD_MARKET_PROVIDER=stooq

# Optional adapter settings.
HYPEBOARD_REQUEST_TIMEOUT_SECONDS=20
HYPEBOARD_REQUEST_RETRIES=3
HYPEBOARD_REQUEST_BACKOFF_SECONDS=1.0
HYPEBOARD_MARKET_REQUEST_DELAY_SECONDS=0.35

# Optional social adapter. Leave unset to keep social data explicitly unavailable.
# The endpoint must return documented Hypeboard-compatible public JSON.
HYPEBOARD_SOCIAL_DATA_URL=

# Reserved for a future separately implemented demo path. The production pipeline
# rejects true so demo and live data cannot be mixed silently.
HYPEBOARD_DEMO_MODE=false
