{
  "$defs": {
    "DataStatus": {
      "enum": [
        "fresh",
        "cached",
        "stale",
        "partial",
        "unavailable"
      ],
      "title": "DataStatus",
      "type": "string"
    },
    "HistoryPoint": {
      "additionalProperties": false,
      "properties": {
        "date": {
          "format": "date",
          "title": "Date",
          "type": "string"
        },
        "price": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Price"
        },
        "daily_return_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Daily Return Pct"
        },
        "volume": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Volume"
        },
        "volume_ratio_30d": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Volume Ratio 30D"
        },
        "wikipedia_pageviews": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Wikipedia Pageviews"
        },
        "wikipedia_change_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Wikipedia Change Pct"
        },
        "short_volume_ratio": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Short Volume Ratio"
        },
        "attention_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Attention Score"
        },
        "trading_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Trading Score"
        },
        "retail_proxy_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retail Proxy Score"
        },
        "impact_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Impact Score"
        },
        "hype_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hype Score"
        },
        "confidence_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence Score"
        },
        "data_status": {
          "$ref": "#/$defs/DataStatus"
        }
      },
      "required": [
        "date",
        "data_status"
      ],
      "title": "HistoryPoint",
      "type": "object"
    },
    "SourceRunStatus": {
      "additionalProperties": false,
      "properties": {
        "source": {
          "title": "Source",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/DataStatus"
        },
        "last_observation_at": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Observation At"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "records": {
          "default": 0,
          "title": "Records",
          "type": "integer"
        },
        "symbols_updated": {
          "default": 0,
          "title": "Symbols Updated",
          "type": "integer"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        },
        "delay_note": {
          "title": "Delay Note",
          "type": "string"
        }
      },
      "required": [
        "source",
        "status",
        "retrieved_at",
        "delay_note"
      ],
      "title": "SourceRunStatus",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "symbol": {
      "title": "Symbol",
      "type": "string"
    },
    "company_name": {
      "title": "Company Name",
      "type": "string"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "score_version": {
      "title": "Score Version",
      "type": "string"
    },
    "points": {
      "items": {
        "$ref": "#/$defs/HistoryPoint"
      },
      "title": "Points",
      "type": "array"
    },
    "sources": {
      "items": {
        "$ref": "#/$defs/SourceRunStatus"
      },
      "title": "Sources",
      "type": "array"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    }
  },
  "required": [
    "symbol",
    "company_name",
    "generated_at",
    "score_version",
    "points",
    "sources",
    "limitations"
  ],
  "title": "SymbolHistoryPayload",
  "type": "object"
}